{
   "name": "dependabot-vuln-viewer",
   "version": "1.0.0",
   "description": "Quick overview of Dependabot vulnerabilites of multiple repositories",
   "repository": {
      "type": "git",
      "url": "git+ssh://git@github.com/nyg/dependabot-vuln-viewer.git"
   },
   "keywords": [
      "dependabot",
      "vulnerabilities",
      "github",
      "graphql",
      "log4shell"
   ],
   "author": "nyg",
   "packageManager": "pnpm@11.5.0",
   "license": "MIT",
   "bugs": {
      "url": "https://github.com/nyg/dependabot-vuln-viewer/issues"
   },
   "scripts": {
      "dev": "next dev",
      "debug": "NODE_OPTIONS='--inspect' next dev",
      "lint": "eslint . --fix"
   },
   "dependencies": {
      "@apollo/client": "4.2.0",
      "@babel/runtime": "7.29.7",
      "github-markdown-css": "5.9.0",
      "graphql": "16.14.0",
      "marked-react": "4.0.0",
      "next": "16.2.6",
      "react": "19.2.6",
      "react-dom": "19.2.6",
      "rxjs": "7.8.2"
   },
   "devDependencies": {
      "@tailwindcss/postcss": "4.3.0",
      "eslint": "9.39.4",
      "eslint-config-next": "16.2.6",
      "postcss": "8.5.15",
      "tailwindcss": "4.3.0"
   },
   "pnpm": {
      "overrides": {
         "baseline-browser-mapping": "latest"
      }
   }
}
